---
// Decorative SVG — TouchDesigner / node graph aesthetic
---

<svg
  class="node-graph"
  viewBox="0 0 400 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <!-- Edges -->
  <line x1="80"  y1="60"  x2="200" y2="120" stroke="rgba(61,122,110,0.35)" stroke-width="1"/>
  <line x1="200" y1="120" x2="320" y2="80"  stroke="rgba(61,122,110,0.35)" stroke-width="1"/>
  <line x1="200" y1="120" x2="200" y2="240" stroke="rgba(61,122,110,0.35)" stroke-width="1"/>
  <line x1="200" y1="240" x2="100" y2="280" stroke="rgba(61,122,110,0.2)"  stroke-width="1"/>
  <line x1="200" y1="240" x2="320" y2="260" stroke="rgba(61,122,110,0.2)"  stroke-width="1"/>
  <line x1="320" y1="80"  x2="360" y2="180" stroke="rgba(61,122,110,0.2)"  stroke-width="1"/>
  <line x1="80"  y1="60"  x2="40"  y2="160" stroke="rgba(61,122,110,0.2)"  stroke-width="1"/>
  <line x1="40"  y1="160" x2="100" y2="280" stroke="rgba(61,122,110,0.15)" stroke-width="1"/>

  <!-- Nodes — larger / brighter = more central -->
  <circle cx="200" cy="120" r="6" fill="var(--color-jade)"       opacity="0.9"/>
  <circle cx="200" cy="240" r="5" fill="var(--color-jade)"       opacity="0.7"/>
  <circle cx="320" cy="80"  r="4" fill="var(--color-jade-light)" opacity="0.5"/>
  <circle cx="80"  cy="60"  r="4" fill="var(--color-jade-light)" opacity="0.5"/>
  <circle cx="100" cy="280" r="3" fill="var(--color-ocean)"      opacity="0.4"/>
  <circle cx="320" cy="260" r="3" fill="var(--color-ocean)"      opacity="0.4"/>
  <circle cx="360" cy="180" r="3" fill="var(--color-ocean)"      opacity="0.4"/>
  <circle cx="40"  cy="160" r="3" fill="var(--color-ocean)"      opacity="0.4"/>

  <!-- Node halos -->
  <circle cx="200" cy="120" r="14" stroke="var(--color-jade)"       stroke-width="0.5" opacity="0.3"/>
  <circle cx="200" cy="240" r="12" stroke="var(--color-jade)"       stroke-width="0.5" opacity="0.2"/>

  <!-- Data flow dots -->
  <circle cx="140" cy="90"  r="1.5" fill="var(--color-amber)" opacity="0.6"/>
  <circle cx="260" cy="100" r="1.5" fill="var(--color-amber)" opacity="0.4"/>
  <circle cx="200" cy="180" r="1.5" fill="var(--color-amber)" opacity="0.5"/>
</svg>

<style>
.node-graph {
  width: 100%;
  max-width: 380px;
  height: auto;
  opacity: 0.85;
}
</style>

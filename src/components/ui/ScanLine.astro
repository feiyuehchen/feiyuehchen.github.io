---
interface Props {
  opacity?: number;
}
const { opacity = 0.025 } = Astro.props;
---

<div class="scan-line" style={`opacity: ${opacity}`} aria-hidden="true"></div>

<style>
.scan-line {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.4) 2px,
    rgba(0, 0, 0, 0.4) 4px
  );
}
</style>

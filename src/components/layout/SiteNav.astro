---
interface Props {
  current?: string;
}
const { current } = Astro.props;

const links = [
  { href: '/',         en: 'Home',     zh: '首頁' },
  { href: '/cv',       en: 'CV',       zh: '履歷' },
  { href: '/research', en: 'Research', zh: '研究' },
  { href: '/project',  en: 'Project',  zh: '作品' },
  { href: '/arts',     en: 'Arts',     zh: '藝術' },
  { href: '/contact',  en: 'Contact',  zh: '聯絡' },
];
---

<nav class="site-nav" id="site-nav">
  <a class="site-nav__logo" href="/">
    <span class="logo-en">FYC</span>
    <span class="logo-zh">陳飛岳</span>
  </a>

  <ul class="site-nav__links" id="nav-links">
    {links.map(link => (
      <li>
        <a
          class="site-nav__link"
          href={link.href}
          aria-current={current === link.href ? 'page' : undefined}
        >
          <span class="lang-en">{link.en}</span>
          <span class="lang-zh">{link.zh}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="site-nav__right">
    <button class="lang-toggle" id="lang-toggle" aria-label="Toggle language">
      <span class="lang-toggle__en">ZH</span>
      <span class="lang-toggle__zh">EN</span>
    </button>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  const html = document.documentElement;
  const langBtn = document.getElementById('lang-toggle');
  const hamburger = document.getElementById('nav-hamburger');
  const navLinks = document.getElementById('nav-links');

  // Restore language
  const saved = localStorage.getItem('lang') ?? 'en';
  html.setAttribute('data-lang', saved);

  langBtn?.addEventListener('click', () => {
    const next = html.getAttribute('data-lang') === 'en' ? 'zh' : 'en';
    html.setAttribute('data-lang', next);
    localStorage.setItem('lang', next);
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const open = navLinks?.classList.toggle('is-open');
    hamburger.setAttribute('aria-expanded', String(open));
    hamburger.classList.toggle('is-open', open ?? false);
  });

  // Close on link click (mobile nav)
  navLinks?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      navLinks.classList.remove('is-open');
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
/* ── Logo ── */
.logo-en {
  font-family: 'Redhat', monospace;
  font-size: 0.85rem;
  letter-spacing: 0.12em;
  color: var(--color-jade-light);
}
.logo-zh {
  font-family: 'TaipeiSansTC', sans-serif;
  font-size: 0.75rem;
  color: var(--color-text-dim);
  margin-left: 0.4em;
}

/* ── Right side controls ── */
.site-nav__right {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

/* ── Language toggle ── */
.lang-toggle {
  background: none;
  border: 1px solid var(--color-border);
  color: var(--color-text-dim);
  font-family: 'Redhat', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  padding: 0.3em 0.6em;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
  flex-shrink: 0;
}
.lang-toggle:hover {
  color: var(--color-jade-light);
  border-color: var(--color-jade-dim);
}

/* ── Hamburger (hidden on desktop) ── */
.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  width: 28px;
  height: 28px;
}
.nav-hamburger span {
  display: block;
  height: 1px;
  background: var(--color-text-secondary);
  transition: transform 0.2s, opacity 0.2s;
  transform-origin: center;
}
.nav-hamburger.is-open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.nav-hamburger.is-open span:nth-child(2) { opacity: 0; }
.nav-hamburger.is-open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

/* ── Language show/hide ── */
:global([data-lang="en"]) .lang-en,
:global([data-lang="zh"]) .lang-zh { display: inline; }
:global([data-lang="en"]) .lang-zh,
:global([data-lang="zh"]) .lang-en { display: none; }

:global([data-lang="en"]) .lang-toggle__en { display: inline; }
:global([data-lang="en"]) .lang-toggle__zh { display: none; }
:global([data-lang="zh"]) .lang-toggle__zh { display: inline; }
:global([data-lang="zh"]) .lang-toggle__en { display: none; }

/* ── Mobile nav ── */
@media (max-width: 640px) {
  .nav-hamburger { display: flex; }

  .site-nav__links {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    flex-direction: column;
    gap: 0;
    background: var(--color-bg-overlay);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 0;
  }
  .site-nav__links.is-open { display: flex; }
  .site-nav__links li { width: 100%; }
  .site-nav__link {
    display: block;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    border-bottom: none !important;
  }
  .site-nav__link[aria-current="page"] {
    color: var(--color-jade-light);
    border-left: 2px solid var(--color-jade);
    padding-left: calc(2rem - 2px);
  }
}
</style>
